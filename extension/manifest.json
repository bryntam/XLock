{
  "manifest_version": 3,
  "name": "Build in Public Gate",
  "version": "0.1.0",
  "description": "Blocks X/Twitter unless a local Codex build session is active.",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:47831/*", "https://x.com/*", "https://twitter.com/*"],
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Build in Public Gate"
  }
}
